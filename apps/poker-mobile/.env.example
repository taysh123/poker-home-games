# ─────────────────────────────────────────────────
# T Poker — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────

# Backend API base URL
# Defaults: http://localhost:5062 (web) | LAN IP:5062 (native)
EXPO_PUBLIC_API_URL=https://poker-home-games-production.up.railway.app

# ── Google OAuth ────────────────────────────────
# Expo Go testing: leave these blank.
#   The hardcoded Expo proxy client ID in useGoogleAuth.ts handles Expo Go.
#
# Production Android builds:
#   1. Google Cloud Console -> APIs & Services -> Credentials
#   2. Create OAuth 2.0 Client ID -> Application type: Android
#   3. Package name: your.bundle.id (from app.json android.package)
#   4. SHA-1: keytool -list -v -keystore ~/.android/debug.keystore -alias androiddebugkey -storepass android
#   5. Paste the resulting Android client ID below
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Production iOS builds:
#   1. Google Cloud Console -> Create OAuth 2.0 Client ID -> Application type: iOS
#   2. Bundle ID: your.bundle.id (from app.json ios.bundleIdentifier)
#   3. Paste the resulting iOS client ID below
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Web / Vercel OAuth client ID:
#   1. Google Cloud Console -> Create OAuth 2.0 Client ID -> Application type: Web
#   2. Add your Vercel domain as an authorized origin
#   3. Paste the resulting Web client ID below
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=12435044751-jdh0dldfhkn2h8hqs3ssegbjflhvcmfi.apps.googleusercontent.com

# ── Billing (RevenueCat mobile + Stripe web) ────
# ALL EMPTY by default ⇒ the real billing adapters stay key-gated and the MOCK provider remains active
# (production-inert). Fill these in only once the accounts/products exist. These are PUBLIC client keys/IDs,
# NOT secrets — server-side SECRET keys (Stripe secret, RevenueCat secret, webhook secrets) live on the backend.
#
# Store product IDs — must match the products you create in App Store Connect / Play Console / Stripe.
# Leave blank to use the documented placeholder defaults (tpoker.premium.monthly / tpoker.premium.yearly).
EXPO_PUBLIC_PREMIUM_MONTHLY_ID=
EXPO_PUBLIC_PREMIUM_YEARLY_ID=
#
# RevenueCat PUBLIC SDK key (mobile). From RevenueCat -> Project -> API keys (the public app key, not the secret).
# Requires installing react-native-purchases (deferred external step — see docs/commercial/billing-architecture.md).
EXPO_PUBLIC_REVENUECAT_API_KEY=
#
# Stripe PUBLISHABLE key (web), e.g. pk_live_... / pk_test_... . The Stripe SECRET key lives on the backend only.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

