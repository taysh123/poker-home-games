# ─────────────────────────────────────────────────
# T Poker — Frontend Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────

# Backend API base URL
# Defaults: http://localhost:5062 (web) | LAN IP:5062 (native)
EXPO_PUBLIC_API_URL=https://poker-home-games-production.up.railway.app

# ── Google OAuth ────────────────────────────────
# Expo Go testing: leave these blank.
#   The hardcoded Expo proxy client ID in useGoogleAuth.ts handles Expo Go.
#
# Production Android builds:
#   1. Google Cloud Console -> APIs & Services -> Credentials
#   2. Create OAuth 2.0 Client ID -> Application type: Android
#   3. Package name: your.bundle.id (from app.json android.package)
#   4. SHA-1: keytool -list -v -keystore ~/.android/debug.keystore -alias androiddebugkey -storepass android
#   5. Paste the resulting Android client ID below
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Production iOS builds:
#   1. Google Cloud Console -> Create OAuth 2.0 Client ID -> Application type: iOS
#   2. Bundle ID: your.bundle.id (from app.json ios.bundleIdentifier)
#   3. Paste the resulting iOS client ID below
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Web / Vercel OAuth client ID:
#   1. Google Cloud Console -> Create OAuth 2.0 Client ID -> Application type: Web
#   2. Add your Vercel domain as an authorized origin
#   3. Paste the resulting Web client ID below
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=12435044751-jdh0dldfhkn2h8hqs3ssegbjflhvcmfi.apps.googleusercontent.com

