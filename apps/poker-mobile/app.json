{
  "expo": {
    "name": "T Poker",
    "slug": "t-poker",
    "scheme": "tpoker",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A111B",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A111B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tpoker.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.12435044751-jap7j5prc6vm0eh0mj517nv0phrlu8mr"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A111B"
      },
      "package": "com.tpoker.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "app.tpoker.app",
              "pathPrefix": "/join"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#0A111B",
      "themeColor": "#0A111B"
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-secure-store",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#C9A84C"
        }
      ],
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "8380f2f3-8dbb-478e-b92f-c39e3ebb3d8b"
      }
    },
    "owner": "taysh"
  }
}
