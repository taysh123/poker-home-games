{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=poker_app;Username=postgres;Password=your_password"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE_THIS_TO_A_SECURE_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "PokerApp",
    "Audience": "PokerApp",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 30
  },
  "GoogleSettings": {
    // OAuth audience allow-list. These are PUBLIC client identifiers (safe to commit).
    // Every Google ID token's `aud` must match one of these or sign-in fails with
    // "Invalid Google token". Override/extend in production via env vars:
    //   GoogleSettings__ClientIds__0, __1, ...
    "ClientIds": [
      "12435044751-jdh0dldfhkn2h8hqs3ssegbjflhvcmfi.apps.googleusercontent.com",
      "12435044751-eruvq9uduc9sk5mietg9eiab2epddsp6.apps.googleusercontent.com",
      "12435044751-jap7j5prc6vm0eh0mj517nv0phrlu8mr.apps.googleusercontent.com"
    ]
  },
  "AppleSettings": {
    // Apple Sign In audience allow-list — the app's bundle id (native flow) and/or the
    // Services ID (web). An Apple identity token's `aud` must match one of these.
    // Override in production via env: AppleSettings__ClientIds__0, __1, ...
    "ClientIds": [
      "com.tpoker.app"
    ]
  },
  "AuthSettings": {
    // Hardened identity (B1). Open email self-registration is OFF — verified providers only.
    // Existing email accounts keep logging in. Social logins may link to a verified same-email account.
    "AllowEmailRegistration": false,
    "AllowEmailLinking": true
  },
  "BillingSettings": {
    // B3 — store verification provider. "mock" (default) keeps dev/test seams; "direct" enables
    // real Apple JWS / Google OIDC verification. AcceptSandbox=true allows sandbox receipts to grant
    // entitlements (DEV ONLY). In production set Provider="direct" and AcceptSandbox=false.
    "Provider": "mock",
    "AcceptSandbox": true
  },
  "AppleStoreSettings": {
    // Apple bundle ids allowed on store transactions, and the Apple Root CA PEM(s) used to anchor the
    // App Store Server Notification / StoreKit2 JWS x5c chain. Empty roots ⇒ verification fails closed.
    // Provide via env in prod: AppleStoreSettings__RootCertsPem__0, AppleStoreSettings__BundleIds__0
    "BundleIds": [ "com.tpoker.app" ],
    "RootCertsPem": []
  },
  "GooglePlaySettings": {
    // Play package name, the OIDC audience configured on the Pub/Sub push subscription, and the service
    // account JSON for the Play Developer API (credential-gated; client is a stub until deploy).
    "PackageName": "com.tpoker.app",
    "PubSubAudience": "",
    "ServiceAccountJson": null
  },
  "CoachAiSettings": {
    // AI Coach provider. "mock" (default, deterministic demo) | "anthropic" (real, requires ApiKey) |
    // "vendor" (generic stub). The key is SERVER-ONLY — set via env CoachAiSettings__ApiKey (Railway).
    // Empty/null ApiKey ⇒ fail closed (the adapter throws; the credit is refunded; never fabricates).
    "Provider": "mock",
    "ApiKey": null,
    "Model": "claude-sonnet-4-6",
    "ApiBase": "https://api.anthropic.com"
  },
  "StripeSettings": {
    // Web billing (Stripe). EMPTY ⇒ inert/fail-closed (mock stays active). Set via env in prod:
    // StripeSettings__SecretKey, __WebhookSecret, __PriceMonthlyId, __PriceYearlyId. Never commit real keys.
    // Success/cancel URLs are derived from AppSettings:WebBaseUrl (not hardcoded here).
    "SecretKey": "",
    "WebhookSecret": "",
    "PriceMonthlyId": "",
    "PriceYearlyId": "",
    "ApiBase": "https://api.stripe.com"
  },
  "RevenueCatSettings": {
    // Mobile billing aggregator (RevenueCat). EMPTY ⇒ inert/fail-closed. Set via env in prod:
    // RevenueCatSettings__SecretApiKey, __WebhookAuthHeader. Never commit real keys.
    "SecretApiKey": "",
    "WebhookAuthHeader": "",
    "ApiBase": "https://api.revenuecat.com"
  },
  "FraudSettings": {
    // B5 — abuse detection. Signals + audit are ALWAYS on; blocking is OFF until tuned against real
    // traffic (EnforceBlocking=false ⇒ advisory only, never blocks legitimate users). Thresholds tunable.
    "EnforceBlocking": false,
    "MaxAccountsPerDevice": 3,
    "VelocityWindowSeconds": 60,
    "MaxAnalysesPerWindow": 10,
    "BlockScore": 100,
    "MultiAccountWeight": 60,
    "VelocityWeight": 70
  },
  "TopUpSettings": {
    // B5 — consumable AI-credit bundles. DISABLED + empty by default ⇒ every redeem fails closed.
    // No live billing: consumable receipt verification is a deploy-time seam — keep Enabled=false until wired.
    "Enabled": false,
    "Bundles": []
  },
  "AppSettings": {
    "WebBaseUrl": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
