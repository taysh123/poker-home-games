{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tpoker.app/schemas/learning-path-doc.schema.json",
  "title": "LearningPathDoc",
  "description": "An ordered learning path. Each step references a lesson, quiz, or range drill by id, with optional unlock rules. Tolerant: unknown fields ignored.",
  "type": "object",
  "required": ["id", "title", "steps"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "tags": { "type": "array", "items": { "type": "string" } },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "ref"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "ref": {
            "type": "object",
            "required": ["type", "id"],
            "properties": {
              "type": { "type": "string", "enum": ["lesson", "quiz", "range_drill"] },
              "id": { "type": "string", "minLength": 1, "description": "Id of the referenced lesson/quiz/range in the same pack." }
            }
          },
          "unlock": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["always", "min_quiz_pct"] },
              "quizId": { "type": "string" },
              "pct": { "type": "number", "minimum": 0, "maximum": 100 }
            },
            "allOf": [
              {
                "if": { "properties": { "type": { "const": "min_quiz_pct" } } },
                "then": { "required": ["quizId", "pct"] }
              }
            ]
          }
        }
      }
    }
  }
}
